#!/usr/bin/env bash
# Build the static website: copy web/ into dist/, served by the host.
# dist/ is cleaned first, except *.aab — release deliverables also land
# there (see CLAUDE.md "Preparing a Release") and must survive.
set -euo pipefail

cd "$(dirname "$0")/.."

mkdir -p dist
find dist -mindepth 1 -maxdepth 1 ! -name '*.aab' -exec rm -rf {} +
cp -r web/. dist/

echo "build: web/ -> dist/"
